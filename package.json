{
  "name": "s2s-attribution-server",
  "version": "1.0.0",
  "description": "Privacy-First Multi-Tenant Server-to-Server Attribution Platform",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "attribution",
    "tracking",
    "s2s",
    "multi-tenant",
    "privacy-first"
  ],
  "author": "Lalitha M V",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "redis": "^4.6.7",
    "ioredis": "^5.3.2",
    "uuid": "^9.0.0",
    "dotenv": "^16.3.1",
    "helmet": "^7.0.0",
    "cors": "^2.8.5",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^6.8.1",
    "ua-parser-js": "^1.0.35",
    "geoip-lite": "^1.4.7",
    "@google-cloud/pubsub": "^4.0.0",
    "@google-cloud/bigquery": "^7.0.0",
    "aws-sdk": "^2.1424.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.4.2",
    "@types/uuid": "^9.0.2",
    "@types/cors": "^2.8.13",
    "@types/morgan": "^1.9.5",
    "@types/compression": "^1.7.2",
    "@types/ua-parser-js": "^0.7.36",
    "typescript": "^5.1.6",
    "tsx": "^3.12.7",
    "jest": "^29.6.1",
    "@types/jest": "^29.5.3",
    "ts-jest": "^29.1.1",
    "eslint": "^8.45.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
